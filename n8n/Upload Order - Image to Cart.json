          "name": "Gemini API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst priceType = $node[\"Prepare Gemini Request\"].json.price_type || \"Retail\";\n\nlet rawText = '';\nif (response.candidates && response.candidates[0]?.content?.parts[0]) {\n  rawText = response.candidates[0].content.parts[0].text;\n}\n\nlet items = [];\ntry {\n  // Standardize the text by removing potential markdown wrapping\n  let cleanText = rawText.trim().replace(/^```json/i, '').replace(/```$/i, '').trim();\n  items = JSON.parse(cleanText);\n  \n  if (!Array.isArray(items)) items = [items];\n\n  items = items.map(item => ({\n    item: String(item.item || item.name || '').trim(),\n    qty: parseInt(item.qty || item.quantity || 1, 10)\n  })).filter(item => item.item.length > 0);\n} catch (e) {\n  items = [];\n}\n\nreturn {\n  items,\n  price_type: priceType\n};"
      },
