    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst imageBase64 = body.image_base64 || '';\n// Extract just the base64 string without the data:image prefix\nconst imageData = imageBase64.replace(/^data:image\\/[a-z]+;base64,/, '');\n\nreturn {\n  geminiPayload: {\n    contents: [\n      {\n        parts: [\n          {\n            inline_data: {\n              mime_type: 'image/jpeg',\n              data: imageData\n            }\n          },\n          {\n            text: 'Extract items and quantities from this shopping list image. Return ONLY a clean JSON array with this exact format: [{\"item\":\"product name\",\"qty\":number}]. Do not include markdown, explanations, or extra text.'\n          }\n        ]\n      }\n    ],\n    generationConfig: {\n      responseMimeType: 'application/json',\n      temperature: 0.1\n    }\n  },\n  price_type: body.price_type || 'Retail'\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
